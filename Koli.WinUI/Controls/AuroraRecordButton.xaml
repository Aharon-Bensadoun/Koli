<UserControl
    x:Class="Koli.WinUI.Controls.AuroraRecordButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Width="132" Height="132" HorizontalAlignment="Center" VerticalAlignment="Center">

        <!-- Outer halo (breathing layer) -->
        <Ellipse x:Name="HaloEllipse"
                 Width="132" Height="132"
                 Fill="{StaticResource AuroraHaloBrush}"
                 Opacity="0"
                 IsHitTestVisible="False"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="HaloScale" ScaleX="0.9" ScaleY="0.9"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Thin aurora orbit ring -->
        <Ellipse x:Name="RingEllipse"
                 Width="80" Height="80"
                 Stroke="{StaticResource AuroraRibbonBrush}"
                 StrokeThickness="1.25"
                 Opacity="0.5"
                 IsHitTestVisible="False"/>

        <!-- The actual interactive button -->
        <Button x:Name="CoreButton"
                Width="64" Height="64"
                CornerRadius="32"
                Background="{StaticResource AuroraDiagonalBrush}"
                Foreground="White"
                BorderThickness="0"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="CoreButton_Click">
            <Grid Width="64" Height="64">
                <!-- Inner soft glow that brightens when active -->
                <Ellipse Width="64" Height="64"
                         Fill="{StaticResource GlassInnerGlowBrush}"
                         Opacity="0.5"
                         IsHitTestVisible="False"/>
                <FontIcon x:Name="GlyphIcon"
                          Glyph="&#xE720;"
                          FontFamily="Segoe Fluent Icons"
                          FontSize="20"
                          Foreground="White"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
            </Grid>
        </Button>
    </Grid>
</UserControl>
