<UserControl
    x:Class="Koli.WinUI.Controls.PageShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="{StaticResource SpacingL}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="{StaticResource SpacingL}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2" VerticalAlignment="Center">
                <TextBlock x:Name="TitleTextBlock"
                           Text="{x:Bind Title, Mode=OneWay}"
                           Style="{StaticResource TitleTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <TextBlock x:Name="SubtitleTextBlock"
                           Text="{x:Bind Subtitle, Mode=OneWay}"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="{x:Bind HasSubtitle, Mode=OneWay}"
                           TextWrapping="WrapWholeWords"/>
            </StackPanel>

            <ContentPresenter Grid.Column="1"
                              Content="{x:Bind HeaderActions, Mode=OneWay}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Right"/>
        </Grid>

        <ContentPresenter Grid.Row="1"
                          Content="{x:Bind PageContent, Mode=OneWay}"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch"/>
    </Grid>
</UserControl>
