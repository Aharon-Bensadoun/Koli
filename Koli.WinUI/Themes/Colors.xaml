<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <!-- Dark theme -->
        <ResourceDictionary x:Key="Default">
            <Color x:Key="AppBackgroundColor">#0E0E12</Color>
            <Color x:Key="SurfaceColor">#181820</Color>
            <Color x:Key="SurfaceHoverColor">#24242E</Color>
            <Color x:Key="SurfaceElevatedColor">#20202A</Color>
            <Color x:Key="CardBackgroundColor">#1C1C26</Color>
            <Color x:Key="BorderColor">#2A2A38</Color>
            <Color x:Key="TextPrimaryColor">#F8FAFC</Color>
            <Color x:Key="TextSecondaryColor">#A3A3B2</Color>
            <Color x:Key="TextTertiaryColor">#717180</Color>

            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
            <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#26CACAD8" />
            <SolidColorBrush x:Key="CardSubtleBackgroundBrush" Color="#14FFFFFF" />
            <SolidColorBrush x:Key="BorderBrush" Color="#26FFFFFF" />
            <SolidColorBrush x:Key="DividerBrush" Color="#1AFFFFFF" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />
        </ResourceDictionary>

        <!-- Light theme -->
        <ResourceDictionary x:Key="Light">
            <Color x:Key="AppBackgroundColor">#F3F3F7</Color>
            <Color x:Key="SurfaceColor">#FFFFFF</Color>
            <Color x:Key="SurfaceHoverColor">#ECECF0</Color>
            <Color x:Key="SurfaceElevatedColor">#FAFAFC</Color>
            <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
            <Color x:Key="BorderColor">#E5E5EC</Color>
            <Color x:Key="TextPrimaryColor">#1A1A20</Color>
            <Color x:Key="TextSecondaryColor">#5C5C68</Color>
            <Color x:Key="TextTertiaryColor">#8A8A95</Color>

            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
            <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#B3FFFFFF" />
            <SolidColorBrush x:Key="CardSubtleBackgroundBrush" Color="#80FFFFFF" />
            <SolidColorBrush x:Key="BorderBrush" Color="#1A000000" />
            <SolidColorBrush x:Key="DividerBrush" Color="#14000000" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />
        </ResourceDictionary>

        <!-- High contrast -->
        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="CardSubtleBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="BorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="DividerBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="{ThemeResource SystemColorGrayTextColor}" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- Theme-agnostic Koli accent (purple identity) -->
    <Color x:Key="AccentPrimaryColor">#7C3AED</Color>
    <Color x:Key="AccentHoverColor">#8B5CF6</Color>
    <Color x:Key="AccentPressedColor">#6D28D9</Color>
    <Color x:Key="AccentGlowColor">#A78BFA</Color>
    <Color x:Key="RecordingPrimaryColor">#EF4444</Color>
    <Color x:Key="SuccessColor">#34D399</Color>
    <Color x:Key="WarningColor">#FBBF24</Color>
    <Color x:Key="ErrorColor">#F87171</Color>

    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimaryColor}" />
    <SolidColorBrush x:Key="AccentFillBrush" Color="{StaticResource AccentPrimaryColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource AccentGlowColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#1F7C3AED" />
    <SolidColorBrush x:Key="RecordingPrimaryBrush" Color="{StaticResource RecordingPrimaryColor}" />
    <SolidColorBrush x:Key="RecordingSoftBrush" Color="#1FEF4444" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />

</ResourceDictionary>
