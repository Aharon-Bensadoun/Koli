<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============== Typography ============== -->

    <Style x:Key="DisplayTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="SemiLight" />
        <Setter Property="CharacterSpacing" Value="-12" />
        <Setter Property="LineHeight" Value="38" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="PageTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource DisplayTitleStyle}" />

    <Style x:Key="HeroTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="-6" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="EyebrowLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Small" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="180" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="SectionLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource EyebrowLabelStyle}" />

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="22" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="TranscriptBodyStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="LineHeight" Value="27" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="CaptionMutedTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Small" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextTertiaryBrush}" />
    </Style>

    <Style x:Key="MonoLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Segoe UI Variable Small" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    </Style>

    <!-- ============== Surfaces ============== -->

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource StrokeSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLarge}" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    </Style>

    <Style x:Key="SubtleCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardSubtleBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource StrokeHairlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}" />
        <Setter Property="Padding" Value="{StaticResource CompactCardPadding}" />
    </Style>

    <Style x:Key="HeroCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardElevatedBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource StrokeSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusXLarge}" />
        <Setter Property="Padding" Value="{StaticResource HeroCardPadding}" />
        <Setter Property="MinHeight" Value="{StaticResource HeroCardMinHeight}" />
    </Style>

    <!-- ============== Chips / badges ============== -->

    <Style x:Key="ChipBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardSubtleBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource StrokeHairlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusSmall}" />
        <Setter Property="Padding" Value="{StaticResource ChipPadding}" />
    </Style>

    <Style x:Key="AccentChipBorderStyle" TargetType="Border" BasedOn="{StaticResource ChipBorderStyle}">
        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AuroraGlowBrush}" />
    </Style>

    <Style x:Key="RecordingChipBorderStyle" TargetType="Border" BasedOn="{StaticResource ChipBorderStyle}">
        <Setter Property="Background" Value="{StaticResource RecordingSoftBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource RecordingPrimaryBrush}" />
    </Style>

    <Style x:Key="SuccessChipBorderStyle" TargetType="Border" BasedOn="{StaticResource ChipBorderStyle}">
        <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
    </Style>

    <Style x:Key="WarningChipBorderStyle" TargetType="Border" BasedOn="{StaticResource ChipBorderStyle}">
        <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" />
    </Style>

    <!-- ============== Buttons ============== -->

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AuroraDiagonalBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}" />
        <Setter Property="Padding" Value="18,9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource CardSubtleBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource StrokeSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}" />
        <Setter Property="Padding" Value="10,6" />
    </Style>

    <!-- Legacy alias: kept so HomePage.xaml fallback record button still works
         even if AuroraRecordButton isn't yet wired in some pages. -->
    <Style x:Key="RecordButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="{StaticResource RecordButtonSize}" />
        <Setter Property="Height" Value="{StaticResource RecordButtonSize}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}" />
        <Setter Property="Background" Value="{StaticResource AuroraDiagonalBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
