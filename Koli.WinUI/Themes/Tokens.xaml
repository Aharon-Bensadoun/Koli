<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Spacing scale (8px base, with finer XXS / XXXL / Hero stops) -->
    <x:Double x:Key="SpacingXXS">2</x:Double>
    <x:Double x:Key="SpacingXS">4</x:Double>
    <x:Double x:Key="SpacingS">8</x:Double>
    <x:Double x:Key="SpacingM">12</x:Double>
    <x:Double x:Key="SpacingL">16</x:Double>
    <x:Double x:Key="SpacingXL">24</x:Double>
    <x:Double x:Key="SpacingXXL">32</x:Double>
    <x:Double x:Key="SpacingXXXL">48</x:Double>
    <x:Double x:Key="SpacingHero">64</x:Double>

    <!-- Radii (softened to feel more "cosmic") -->
    <CornerRadius x:Key="RadiusSmall">6</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">10</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">16</CornerRadius>
    <CornerRadius x:Key="RadiusXLarge">22</CornerRadius>
    <CornerRadius x:Key="RadiusPill">999</CornerRadius>

    <!-- Padding presets -->
    <Thickness x:Key="PagePadding">32</Thickness>
    <Thickness x:Key="PagePaddingCompact">24</Thickness>
    <Thickness x:Key="CardPadding">20</Thickness>
    <Thickness x:Key="CompactCardPadding">14</Thickness>
    <Thickness x:Key="HeroCardPadding">28</Thickness>
    <Thickness x:Key="ChipPadding">12,5</Thickness>

    <!-- Layout caps -->
    <x:Double x:Key="PageContentMaxWidth">1180</x:Double>
    <x:Double x:Key="PageContentReadableWidth">760</x:Double>

    <!-- Chrome -->
    <x:Double x:Key="TitleBarHeight">44</x:Double>

    <!-- Hero / record -->
    <x:Double x:Key="RecordButtonSize">64</x:Double>
    <x:Double x:Key="RecordHaloSize">132</x:Double>
    <x:Double x:Key="HeroCardMinHeight">280</x:Double>

    <!-- Motion tuning (consumed by Motion.xaml) -->
    <x:Double x:Key="HaloMaxOpacity">0.55</x:Double>
    <x:Double x:Key="HaloMinOpacity">0.18</x:Double>
    <x:Double x:Key="BreathingDurationSeconds">2.4</x:Double>
    <x:Double x:Key="HoverLiftOffset">-1</x:Double>
    <x:Double x:Key="HoverLiftScale">1.012</x:Double>

</ResourceDictionary>
