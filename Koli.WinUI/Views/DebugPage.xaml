<Page
    x:Class="Koli.WinUI.Views.DebugPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Koli.WinUI.Controls">

    <controls:PageShell Title="Debug" Subtitle="Real-time application log">
        <controls:PageShell.HeaderActions>
            <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingS}">
                <Button Command="{Binding ClearCommand}" ToolTipService.ToolTip="Clear">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74D;" FontSize="13"/>
                        <TextBlock Text="Clear"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding CopyCommand}" ToolTipService.ToolTip="Copy log to clipboard">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8C8;" FontSize="13"/>
                        <TextBlock Text="Copy"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ExportCommand}" Style="{StaticResource PrimaryButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74E;" FontSize="13" Foreground="White"/>
                        <TextBlock Text="Export"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </controls:PageShell.HeaderActions>

        <Border Style="{StaticResource CardBorderStyle}" Padding="0">
            <TextBox Text="{Binding LogText, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     FontFamily="Cascadia Mono, Consolas"
                     FontSize="12"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="14"/>
        </Border>
    </controls:PageShell>
</Page>
