<Page
    x:Class="Koli.WinUI.Views.DebugPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Koli.WinUI.Controls">

    <controls:PageShell Eyebrow="DEVELOPER"
                        Title="Debug console"
                        Subtitle="Live application log — every request and response">
        <controls:PageShell.HeaderActions>
            <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingS}">
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ClearCommand}" ToolTipService.ToolTip="Clear">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74D;" FontSize="13"/>
                        <TextBlock Text="Clear"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding CopyCommand}" ToolTipService.ToolTip="Copy log to clipboard">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8C8;" FontSize="13"/>
                        <TextBlock Text="Copy"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ExportCommand}" Style="{StaticResource PrimaryButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74E;" FontSize="13" Foreground="White"/>
                        <TextBlock Text="Export"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </controls:PageShell.HeaderActions>

        <Border Background="{ThemeResource VoidBrush}"
                BorderBrush="{ThemeResource StrokeSoftBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLarge}"
                Padding="2">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Faux terminal title strip -->
                <Grid Padding="14,10" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="10" Height="10" Fill="{StaticResource RecordingPrimaryBrush}"/>
                    <Ellipse Grid.Column="1" Width="10" Height="10" Fill="{StaticResource WarningBrush}"/>
                    <Ellipse Grid.Column="2" Width="10" Height="10" Fill="{StaticResource SuccessBrush}"/>
                    <TextBlock Grid.Column="4"
                               Text="koli ~ debug.log"
                               Style="{StaticResource MonoLabelStyle}"
                               Opacity="0.7"
                               VerticalAlignment="Center"/>
                </Grid>

                <controls:AuroraDivider Grid.Row="0" VerticalAlignment="Bottom"/>

                <TextBox Grid.Row="1"
                         Text="{Binding LogText, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="12"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="16"/>
            </Grid>
        </Border>
    </controls:PageShell>
</Page>
