<Page
    x:Class="Koli.WinUI.Views.HistoryPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Koli.WinUI.Controls"
    xmlns:models="using:Koli.Models"
    xmlns:services="using:Koli.Services">

    <controls:PageShell Eyebrow="HISTORY"
                        Title="Recent transcriptions"
                        Subtitle="Past captures and pending retries">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="{StaticResource SpacingXXL}"
                        MaxWidth="{StaticResource PageContentMaxWidth}"
                        HorizontalAlignment="Stretch">

                <!-- Pending recordings (retry queue) -->
                <StackPanel Spacing="{StaticResource SpacingM}"
                            Visibility="{Binding PendingEntries, Converter={StaticResource CollectionVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="PENDING RECORDINGS"
                                   Style="{StaticResource EyebrowLabelStyle}"
                                   Foreground="{StaticResource WarningBrush}"/>
                        <Border Width="20" Height="2" CornerRadius="1"
                                Background="{StaticResource WarningBrush}"
                                VerticalAlignment="Center"
                                Opacity="0.7"/>
                    </StackPanel>

                    <InfoBar IsOpen="True"
                             IsClosable="False"
                             Severity="Warning"
                             Title="Recordings waiting for retry"
                             Message="These captures could not be transcribed. Use Retry once your connection is back."/>

                    <ItemsControl ItemsSource="{Binding PendingEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="services:PendingAudioEntry">
                                <Grid Margin="0,0,0,10" ColumnSpacing="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{StaticResource WarningBrush}"
                                            CornerRadius="2,0,0,2"/>
                                    <Border Grid.Column="1"
                                            Background="{ThemeResource CardBackgroundBrush}"
                                            BorderBrush="{ThemeResource StrokeSoftBrush}"
                                            BorderThickness="1,1,1,1"
                                            CornerRadius="0,16,16,0"
                                            Padding="20,16">
                                        <Grid ColumnSpacing="14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Glyph="&#xE7BA;"
                                                      FontSize="20"
                                                      Foreground="{StaticResource WarningBrush}"
                                                      VerticalAlignment="Top"/>
                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <TextBlock Text="Pending"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource WarningBrush}"/>
                                                    <TextBlock Text="·" Foreground="{ThemeResource TextTertiaryBrush}"/>
                                                    <TextBlock Text="{x:Bind CapturedAt}"
                                                               Foreground="{ThemeResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind LastError}"
                                                           Foreground="{ThemeResource TextTertiaryBrush}"
                                                           TextWrapping="WrapWholeWords"
                                                           FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        Spacing="6"
                                                        VerticalAlignment="Center">
                                                <Button Click="PendingPlay_Click" Tag="{x:Bind}"
                                                        ToolTipService.ToolTip="Play"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Padding="8">
                                                    <FontIcon Glyph="&#xE768;" FontSize="13"/>
                                                </Button>
                                                <Button Click="PendingRetry_Click" Tag="{x:Bind}"
                                                        ToolTipService.ToolTip="Retry"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Padding="12,7">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <FontIcon Glyph="&#xE72C;" FontSize="12" Foreground="White"/>
                                                        <TextBlock Text="Retry"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Click="PendingDelete_Click" Tag="{x:Bind}"
                                                        ToolTipService.ToolTip="Delete"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Padding="8">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="13"
                                                              Foreground="{StaticResource ErrorBrush}"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Past transcripts -->
                <StackPanel Spacing="{StaticResource SpacingM}">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="TRANSCRIPTS"
                                   Style="{StaticResource EyebrowLabelStyle}"
                                   Foreground="{StaticResource AuroraGlowBrush}"/>
                        <Border Width="20" Height="2" CornerRadius="1"
                                Background="{StaticResource EyebrowUnderlineBrush}"
                                VerticalAlignment="Center"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:TranscriptHistoryEntry">
                                <Grid Margin="0,0,0,10" ColumnSpacing="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{StaticResource AuroraVerticalBrush}"
                                            CornerRadius="2,0,0,2"/>
                                    <Border Grid.Column="1"
                                            Background="{ThemeResource CardBackgroundBrush}"
                                            BorderBrush="{ThemeResource StrokeSoftBrush}"
                                            BorderThickness="1"
                                            CornerRadius="0,16,16,0"
                                            Padding="20,16">
                                        <Grid RowSpacing="10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Style="{StaticResource AccentChipBorderStyle}">
                                                    <TextBlock Text="{x:Bind Language}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource AuroraGlowBrush}"/>
                                                </Border>
                                                <Button Grid.Column="2"
                                                        Click="CopyTranscript_Click" Tag="{x:Bind}"
                                                        ToolTipService.ToolTip="Copy to clipboard"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Padding="8">
                                                    <FontIcon Glyph="&#xE8C8;" FontSize="13"/>
                                                </Button>
                                            </Grid>
                                            <TextBlock Grid.Row="1"
                                                       Text="{x:Bind Text}"
                                                       Style="{StaticResource BodyTextStyle}"
                                                       MaxLines="4"
                                                       TextTrimming="WordEllipsis"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </controls:PageShell>
</Page>
