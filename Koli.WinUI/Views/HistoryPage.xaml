<Page
    x:Class="Koli.WinUI.Views.HistoryPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Koli.Models"
    xmlns:services="using:Koli.Services">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="History" Style="{StaticResource PageTitleStyle}"/>

            <TextBlock Text="Pending recordings" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}"/>
            <ItemsControl ItemsSource="{Binding PendingEntries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="services:PendingAudioEntry">
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="PENDING" Foreground="{StaticResource WarningBrush}" FontWeight="Bold"/>
                                <TextBlock Text="{x:Bind CapturedAt}" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind LastError}" Foreground="{StaticResource TextTertiaryBrush}" TextWrapping="WrapWholeWords"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Play" Click="PendingPlay_Click" Tag="{x:Bind}"/>
                                    <Button Content="Retry" Click="PendingRetry_Click" Tag="{x:Bind}"/>
                                    <Button Content="Delete" Click="PendingDelete_Click" Tag="{x:Bind}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Transcripts" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
            <ItemsControl ItemsSource="{Binding Entries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:TranscriptHistoryEntry">
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                            <StackPanel Spacing="8">
                                <TextBlock Foreground="{StaticResource AccentGlowBrush}">
                                    <Run Text="{x:Bind Language}"/>
                                </TextBlock>
                                <TextBlock Text="{x:Bind Text}" TextWrapping="WrapWholeWords" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Button Content="Copy" HorizontalAlignment="Left" Click="CopyTranscript_Click" Tag="{x:Bind}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
