<Page
    x:Class="Koli.WinUI.Views.HistoryPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Koli.WinUI.Controls"
    xmlns:models="using:Koli.Models"
    xmlns:services="using:Koli.Services">

    <controls:PageShell Title="History" Subtitle="Your recent transcriptions and retry queue">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="{StaticResource SpacingXL}" MaxWidth="{StaticResource PageContentMaxWidth}" HorizontalAlignment="Stretch">

                <!-- Pending section (only visible when there are pending entries) -->
                <StackPanel Spacing="{StaticResource SpacingS}"
                            Visibility="{Binding PendingEntries, Converter={StaticResource CollectionVisibilityConverter}}">
                    <TextBlock Text="PENDING RECORDINGS" Style="{StaticResource SectionLabelStyle}"
                               Foreground="{StaticResource WarningBrush}"/>

                    <InfoBar IsOpen="True"
                             IsClosable="False"
                             Severity="Warning"
                             Title="Recordings waiting for retry"
                             Message="These captures could not be transcribed. Use Retry once your connection is back."/>

                    <ItemsControl ItemsSource="{Binding PendingEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="services:PendingAudioEntry">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{StaticResource WarningBrush}"
                                        BorderThickness="4,1,1,1"
                                        CornerRadius="{StaticResource RadiusLarge}"
                                        Padding="16"
                                        Margin="0,0,0,10">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE7BA;"
                                                  FontSize="18"
                                                  Foreground="{StaticResource WarningBrush}"
                                                  VerticalAlignment="Top"/>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <TextBlock Text="Pending"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource WarningBrush}"/>
                                                <TextBlock Text="·" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                                <TextBlock Text="{x:Bind CapturedAt}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind LastError}"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                       TextWrapping="WrapWholeWords"
                                                       FontSize="12"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Spacing="4"
                                                    VerticalAlignment="Center">
                                            <Button Click="PendingPlay_Click" Tag="{x:Bind}"
                                                    ToolTipService.ToolTip="Play"
                                                    Padding="8">
                                                <FontIcon Glyph="&#xE768;" FontSize="13"/>
                                            </Button>
                                            <Button Click="PendingRetry_Click" Tag="{x:Bind}"
                                                    ToolTipService.ToolTip="Retry"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Padding="10,6">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xE72C;" FontSize="12" Foreground="White"/>
                                                    <TextBlock Text="Retry"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Click="PendingDelete_Click" Tag="{x:Bind}"
                                                    ToolTipService.ToolTip="Delete"
                                                    Padding="8">
                                                <FontIcon Glyph="&#xE74D;" FontSize="13"
                                                          Foreground="{StaticResource ErrorBrush}"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Transcripts section -->
                <StackPanel Spacing="{StaticResource SpacingS}">
                    <TextBlock Text="TRANSCRIPTS" Style="{StaticResource SectionLabelStyle}"/>

                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:TranscriptHistoryEntry">
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
                                    <Grid RowSpacing="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource AccentChipBorderStyle}">
                                                <TextBlock Text="{x:Bind Language}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentGlowBrush}"/>
                                            </Border>
                                            <Button Grid.Column="2"
                                                    Click="CopyTranscript_Click" Tag="{x:Bind}"
                                                    ToolTipService.ToolTip="Copy to clipboard"
                                                    Padding="8">
                                                <FontIcon Glyph="&#xE8C8;" FontSize="13"/>
                                            </Button>
                                        </Grid>
                                        <TextBlock Grid.Row="1"
                                                   Text="{x:Bind Text}"
                                                   TextWrapping="WrapWholeWords"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                   MaxLines="4"
                                                   TextTrimming="WordEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </controls:PageShell>
</Page>
