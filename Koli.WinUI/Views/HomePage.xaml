<Page
    x:Class="Koli.WinUI.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Koli.WinUI.Controls">

    <Grid>
        <!-- Subtle aurora bleed signs the home view without crowding -->
        <Border IsHitTestVisible="False"
                Background="{StaticResource AuroraPageBleedBrush}"
                Opacity="0.55"/>

        <controls:PageShell Eyebrow="DICTATION"
                            Title="Live transcription"
                            Subtitle="F9 dictate · Alt Gr assistant · F6 pause · F7 cancel">

            <controls:PageShell.HeaderActions>
                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingS}" VerticalAlignment="Center">

                    <Border Style="{StaticResource ChipBorderStyle}"
                            ToolTipService.ToolTip="Detected from the Windows keyboard">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE8D3;" FontSize="11"
                                      Foreground="{ThemeResource TextTertiaryBrush}"/>
                            <TextBlock Text="{Binding InputLanguageChip}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenOutputLanguageSettingsCommand}"
                            IsEnabled="{Binding IsOutputLanguageAvailable, Mode=OneWay}"
                            Padding="12,5"
                            ToolTipService.ToolTip="Output text language">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xF2B7;" FontSize="11"
                                      Foreground="{StaticResource AuroraGlowBrush}"/>
                            <TextBlock Text="{Binding OutputLanguageChip}"
                                       FontSize="12" FontWeight="SemiBold"/>
                            <FontIcon Glyph="&#xE70D;" FontSize="9"
                                      Foreground="{ThemeResource TextTertiaryBrush}"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </controls:PageShell.HeaderActions>

            <Grid RowSpacing="{StaticResource SpacingXL}"
                  MaxWidth="{StaticResource PageContentMaxWidth}"
                  HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HERO CARD : live transcript -->
                <Border Style="{StaticResource HeroCardStyle}">
                    <Grid RowSpacing="{StaticResource SpacingL}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header row: title + status + badges + timer -->
                        <Grid ColumnSpacing="{StaticResource SpacingM}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TranscriptTitle}"
                                           Style="{StaticResource HeroTitleStyle}"/>
                                <TextBlock Text="{Binding StatusText}"
                                           Style="{StaticResource CaptionMutedTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        Spacing="{StaticResource SpacingS}"
                                        VerticalAlignment="Center">
                                <Border Style="{StaticResource AccentChipBorderStyle}"
                                        Visibility="{Binding IsAssistantRecording, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8" Fill="{StaticResource AuroraCyanBrush}"/>
                                        <TextBlock Text="Assistant" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AuroraGlowBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource RecordingChipBorderStyle}"
                                        Visibility="{Binding IsDictationRecording, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8" Fill="{StaticResource RecordingPrimaryBrush}"/>
                                        <TextBlock Text="REC" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource RecordingPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding TimerText}"
                                           VerticalAlignment="Center"
                                           FontFamily="Cascadia Mono"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Thin aurora divider -->
                        <controls:AuroraDivider Grid.Row="1"/>

                        <!-- Transcript body -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding LiveTranscript}"
                                       Style="{StaticResource TranscriptBodyStyle}"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ACTION ROW : record button, waveform, keybindings -->
                <Grid Grid.Row="1" ColumnSpacing="{StaticResource SpacingXL}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <controls:AuroraRecordButton x:Name="RecordButton"
                                                 Glyph="{Binding RecordButtonGlyph}"
                                                 Command="{Binding ToggleRecordingCommand}"
                                                 ToolTip="Start / stop dictation (F9)"
                                                 VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Spacing="{StaticResource SpacingS}" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock Text="AUDIO" Style="{StaticResource EyebrowLabelStyle}"/>
                            <Border Width="20" Height="2" CornerRadius="1"
                                    Background="{StaticResource EyebrowUnderlineBrush}"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                        <controls:WaveformBar Level="{Binding AudioLevel, Mode=OneWay}"/>
                    </StackPanel>

                    <!-- Keyboard chip strip -->
                    <StackPanel Grid.Column="2" Orientation="Vertical" Spacing="6" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Style="{StaticResource ChipBorderStyle}" Padding="8,3">
                                <TextBlock Text="F9" Style="{StaticResource MonoLabelStyle}"/>
                            </Border>
                            <TextBlock Text="Toggle dictation"
                                       Style="{StaticResource CaptionMutedTextStyle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Style="{StaticResource AccentChipBorderStyle}" Padding="8,3">
                                <TextBlock Text="Alt Gr" Style="{StaticResource MonoLabelStyle}"
                                           Foreground="{StaticResource AuroraGlowBrush}"/>
                            </Border>
                            <TextBlock Text="Voice assistant"
                                       Style="{StaticResource CaptionMutedTextStyle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Style="{StaticResource ChipBorderStyle}" Padding="8,3">
                                <TextBlock Text="F6 / F7" Style="{StaticResource MonoLabelStyle}"/>
                            </Border>
                            <TextBlock Text="Pause / cancel"
                                       Style="{StaticResource CaptionMutedTextStyle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </controls:PageShell>
    </Grid>
</Page>
