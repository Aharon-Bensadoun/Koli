<Page
    x:Class="Koli.WinUI.Views.MeetingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Koli.WinUI.ViewModels">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Spacing="12">
            <TextBlock Text="Meeting" Style="{StaticResource PageTitleStyle}"/>
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding Title, Mode=TwoWay}" PlaceholderText="Meeting title"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding AudioSources}" SelectedIndex="{Binding AudioSourceIndex, Mode=TwoWay}"/>
                <Button Grid.Column="2" Content="Start" Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding StartCommand}" IsEnabled="{Binding IsRecording, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"/>
                <Button Grid.Column="3" Content="Stop" Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding StopCommand}" IsEnabled="{Binding IsRecording, Mode=OneWay}"/>
                <Button Grid.Column="4" Content="Export" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ExportCommand}"/>
            </Grid>
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextSecondaryBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="{Binding TimerText}" FontFamily="Cascadia Mono"/>
                <Border BorderBrush="{StaticResource AccentGlowBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,4"
                        Visibility="{Binding ShowOutputLanguageBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding OutputLanguageBadge}" FontWeight="SemiBold" Foreground="{StaticResource AccentGlowBrush}"/>
                </Border>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Segments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MeetingSegmentViewModel">
                            <StackPanel Margin="0,8,0,8" Spacing="4">
                                <TextBlock Text="{x:Bind SpeakerId}" FontWeight="SemiBold" Foreground="{StaticResource AccentGlowBrush}"/>
                                <TextBlock Text="{x:Bind Text}" TextWrapping="WrapWholeWords" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <StackPanel Grid.Column="1" Spacing="8">
                <TextBlock Text="Participants" FontWeight="SemiBold"/>
                <ItemsControl ItemsSource="{Binding Participants}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ParticipantViewModel">
                            <TextBlock Text="{x:Bind Name}" Margin="0,4" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding AudioLevel}" Foreground="{StaticResource TextTertiaryBrush}"/>
    </Grid>
</Page>
