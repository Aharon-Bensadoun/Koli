<Page
    x:Class="Koli.WinUI.Views.MeetingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Koli.WinUI.Controls"
    xmlns:vm="using:Koli.WinUI.ViewModels">

    <controls:PageShell Eyebrow="MEETING MODE"
                        Title="Multi-speaker capture"
                        Subtitle="Diarized transcript with per-speaker color and export">

        <controls:PageShell.HeaderActions>
            <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingS}">
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding StartCommand}"
                        IsEnabled="{Binding IsRecording, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE7C8;" FontSize="12" Foreground="White"/>
                        <TextBlock Text="Start"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsRecording, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE71A;" FontSize="12"/>
                        <TextBlock Text="Stop"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ExportCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74E;" FontSize="12"/>
                        <TextBlock Text="Export"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </controls:PageShell.HeaderActions>

        <Grid RowSpacing="{StaticResource SpacingXL}"
              MaxWidth="{StaticResource PageContentMaxWidth}"
              HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Session metadata strip -->
            <Border Style="{StaticResource CardBorderStyle}">
                <Grid ColumnSpacing="{StaticResource SpacingL}" RowSpacing="{StaticResource SpacingS}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox Header="Meeting title"
                             Text="{Binding Title, Mode=TwoWay}"
                             PlaceholderText="Meeting title"/>
                    <ComboBox Grid.Column="1"
                              Header="Audio source"
                              HorizontalAlignment="Stretch"
                              ItemsSource="{Binding AudioSources}"
                              SelectedIndex="{Binding AudioSourceIndex, Mode=TwoWay}"/>
                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Spacing="4">
                        <TextBlock Text="STATUS" Style="{StaticResource EyebrowLabelStyle}"/>
                        <TextBlock Text="{Binding StatusText}"
                                   Style="{StaticResource CaptionMutedTextStyle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Spacing="4" HorizontalAlignment="Right">
                        <TextBlock Text="DURATION"
                                   Style="{StaticResource EyebrowLabelStyle}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding TimerText}"
                                   FontFamily="Cascadia Mono" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.ColumnSpan="4"
                                Orientation="Horizontal" Spacing="{StaticResource SpacingS}"
                                Visibility="{Binding ShowOutputLanguageBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Style="{StaticResource AccentChipBorderStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xF2B7;" FontSize="11"
                                          Foreground="{StaticResource AuroraGlowBrush}"/>
                                <TextBlock Text="{Binding OutputLanguageBadge}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource AuroraGlowBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Transcript + participants -->
            <Grid Grid.Row="1" ColumnSpacing="{StaticResource SpacingXL}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource HeroCardStyle}" Padding="0">
                    <Grid RowSpacing="{StaticResource SpacingS}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Padding="24,20,24,8" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Transcript"
                                       Style="{StaticResource HeroTitleStyle}"/>
                            <Border Grid.Column="1" Style="{StaticResource ChipBorderStyle}">
                                <TextBlock Text="{Binding Segments.Count, Mode=OneWay, FallbackValue=0}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextSecondaryBrush}"/>
                            </Border>
                        </Grid>

                        <controls:AuroraDivider Grid.Row="1" Margin="24,0"/>

                        <ScrollViewer Grid.Row="2" Padding="24,12,24,24" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Segments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MeetingSegmentViewModel">
                                        <Grid Margin="0,0,0,10" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Left aurora-tinted rail -->
                                            <Border Width="3"
                                                    Background="{x:Bind ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                    CornerRadius="2"/>

                                            <Border Grid.Column="1"
                                                    Background="{ThemeResource CardSubtleBackgroundBrush}"
                                                    BorderBrush="{ThemeResource StrokeHairlineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource RadiusMedium}"
                                                    Padding="14,12">
                                                <Grid RowSpacing="6">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                        <Ellipse Width="10" Height="10"
                                                                 Fill="{x:Bind ColorHex, Converter={StaticResource HexToBrushConverter}}"/>
                                                        <TextBlock Text="{x:Bind SpeakerId}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   Foreground="{x:Bind ColorHex, Converter={StaticResource HexToBrushConverter}}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Row="1"
                                                               Text="{x:Bind Text}"
                                                               Style="{StaticResource BodyTextStyle}"/>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <Grid RowSpacing="{StaticResource SpacingM}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Participants"
                                       Style="{StaticResource HeroTitleStyle}"/>
                            <Border Grid.Column="1" Style="{StaticResource ChipBorderStyle}">
                                <TextBlock Text="{Binding Participants.Count, Mode=OneWay, FallbackValue=0}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextSecondaryBrush}"/>
                            </Border>
                        </Grid>
                        <controls:AuroraDivider Grid.Row="1"/>
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Participants}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ParticipantViewModel">
                                        <Grid ColumnSpacing="12" Margin="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <PersonPicture Width="36" Height="36"
                                                           DisplayName="{x:Bind Name}"
                                                           Initials="{x:Bind Name, Converter={StaticResource NameToInitialsConverter}}"
                                                           BorderBrush="{x:Bind ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                           BorderThickness="2"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind Name}"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Audio level (waveform) -->
            <Grid Grid.Row="2" ColumnSpacing="{StaticResource SpacingL}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="AUDIO"
                           Style="{StaticResource EyebrowLabelStyle}"
                           VerticalAlignment="Center"/>
                <controls:WaveformBar Grid.Column="1"
                                      Level="{Binding AudioLevel, Mode=OneWay}"/>
            </Grid>
        </Grid>

    </controls:PageShell>
</Page>
