<Page
    x:Class="Koli.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Koli.WinUI.Controls">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="720">
            <TextBlock Text="Settings" Style="{StaticResource PageTitleStyle}"/>

            <Button Content="Configure API…" HorizontalAlignment="Left" Command="{Binding ConfigureApiCommand}"/>

            <TextBlock Text="General" FontWeight="SemiBold"
                       Visibility="{Binding IsLaunchAtStartupAvailable, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <ToggleSwitch Header="Launch at Windows sign-in"
                          IsOn="{Binding LaunchAtStartup, Mode=TwoWay}"
                          Visibility="{Binding IsLaunchAtStartupAvailable, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <TextBlock Text="Also available under Settings → Apps → Startup apps."
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Visibility="{Binding IsLaunchAtStartupAvailable, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <ToggleSwitch Header="Enable text rewriting" IsOn="{Binding RewriteEnabled, Mode=TwoWay}"/>
            <TextBlock Text="Rewrite style"/>
            <ComboBox ItemsSource="{Binding RewriteLevels}" SelectedItem="{Binding RewriteLevel, Mode=TwoWay}"/>

            <TextBlock Text="Output language" FontWeight="SemiBold"/>
            <TextBlock Text="Available with OpenAI / Azure OpenAI only."
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Visibility="{Binding ShowOnPremOutputLanguageNotice, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <ComboBox Header="Mode"
                      ItemsSource="{Binding OutputLanguageModes}"
                      SelectedItem="{Binding SelectedOutputLanguageMode, Mode=TwoWay}"
                      IsEnabled="{Binding IsOutputLanguageAvailable, Mode=OneWay}"/>
            <ComboBox Header="Target language"
                      ItemsSource="{Binding TargetLanguageOptions}"
                      SelectedItem="{Binding SelectedTargetLanguage, Mode=TwoWay}"
                      IsEnabled="{Binding IsTargetLanguageEnabled, Mode=OneWay}"/>

            <TextBlock Text="Voice assistant (Alt Gr)" FontWeight="SemiBold"/>
            <TextBlock Text="Alt Gr = ask a spoken question; Koli types the answer into the active window."
                       Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="WrapWholeWords"/>
            <ToggleSwitch Header="Enable voice assistant (Alt Gr)" IsOn="{Binding AssistantEnabled, Mode=TwoWay}"/>
            <ToggleSwitch Header="Web search" IsOn="{Binding AssistantWebSearchEnabled, Mode=TwoWay}"/>
            <TextBox Header="Assistant model" Text="{Binding AssistantModel, Mode=TwoWay}" PlaceholderText="gpt-4.1"/>

            <TextBlock Text="Typing" FontWeight="SemiBold"/>
            <ToggleSwitch Header="Auto space" IsOn="{Binding TypingAutoSpace, Mode=TwoWay}"/>
            <ToggleSwitch Header="Type in active window" IsOn="{Binding TypingInActiveWindow, Mode=TwoWay}"/>
            <ToggleSwitch Header="Streaming mode" IsOn="{Binding TypingStreamingMode, Mode=TwoWay}"/>

            <Button Content="Save settings" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Command="{Binding SaveCommand}"/>

            <Border Style="{StaticResource CardBorderStyle}">
                <TextBlock Text="{Binding AboutText}" TextWrapping="WrapWholeWords" Foreground="{StaticResource TextSecondaryBrush}"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
