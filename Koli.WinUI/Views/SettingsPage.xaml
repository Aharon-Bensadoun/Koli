<Page
    x:Class="Koli.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="720">
            <TextBlock Text="Settings" Style="{StaticResource PageTitleStyle}"/>

            <Button Content="Configure API…" HorizontalAlignment="Left" Command="{Binding ConfigureApiCommand}"/>

            <ToggleSwitch Header="Enable text rewriting" IsOn="{Binding RewriteEnabled, Mode=TwoWay}"/>
            <TextBlock Text="Rewrite style"/>
            <ComboBox ItemsSource="{Binding RewriteLevels}" SelectedItem="{Binding RewriteLevel, Mode=TwoWay}"/>

            <ToggleSwitch Header="Enable translation" IsOn="{Binding TranslationEnabled, Mode=TwoWay}"/>
            <TextBlock Text="Translation target language (ISO code)"/>
            <TextBox Text="{Binding TranslationTarget, Mode=TwoWay}"/>

            <TextBlock Text="Typing" FontWeight="SemiBold"/>
            <ToggleSwitch Header="Auto space" IsOn="{Binding TypingAutoSpace, Mode=TwoWay}"/>
            <ToggleSwitch Header="Type in active window" IsOn="{Binding TypingInActiveWindow, Mode=TwoWay}"/>
            <ToggleSwitch Header="Streaming mode" IsOn="{Binding TypingStreamingMode, Mode=TwoWay}"/>

            <Button Content="Save settings" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Command="{Binding SaveCommand}"/>

            <Border Style="{StaticResource CardBorderStyle}">
                <TextBlock Text="{Binding AboutText}" TextWrapping="WrapWholeWords" Foreground="{StaticResource TextSecondaryBrush}"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
